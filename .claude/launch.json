{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Firebase Hosting (serve)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["serve", "--only", "hosting", "--port", "5000"],
      "port": 5000
    },
    {
      "name": "Static server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
